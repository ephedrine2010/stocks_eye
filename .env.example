# Stocks Eye — environment config
# Copy to ".env" and fill in as you obtain keys. Everything works keyless without these
# (crypto is live via CoinGecko; equities/gold via Yahoo; news/AI fall back to mock).

# Server
PORT=3000

# --- Optional API keys (add when you have them) ---

# Anthropic (Claude) — enables the real per-market AI Take + Morning Brief.
# Without it, the AI layer returns grounded mock text. Requires:  npm i @anthropic-ai/sdk
ANTHROPIC_API_KEY=

# Finnhub — better US market data (optional; Yahoo is the keyless default)
FINNHUB_API_KEY=

# Marketaux — MENA news + sentiment (optional; RSS/mock is the keyless default)
MARKETAUX_API_KEY=
